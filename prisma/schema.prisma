generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  // admin plugin (better-auth)
  role          String?   @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]

  // app relations
  recipes       Recipe[]
  products      Product[]
  prices        Price[]
  hikings       Hiking[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?  // admin plugin (better-auth)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// models for the app
model Recipe {
  id            String	  @id @default(uuid())
  user_id       String
  category_id   String
  name          String
  description   String?      
  
  user          User           @relation(fields: [user_id], references: [id])
  category      RecipeCategory @relation(fields: [category_id], references: [id])
  ingredients   Ingredient[]
}

model RecipeCategory {
  id            String	     @id @default(uuid())
  name          String       @unique   //Супы, Каши
  recipes       Recipe[]
}

model Ingredient {
  id                String	     @id @default(uuid())
  recipe_id         String	     
  product_id        String
  quantity          Float	         

  recipe            Recipe    @relation(fields: [recipe_id], references: [id])
  product           Product   @relation(fields: [product_id], references: [id])
}

model Product {
  id                  String   @id @default(uuid())
  name                String   @unique
  kkal                Float    @default(0)
  proteins            Float    @default(0)
  fats                Float    @default(0)
  carbohydrates       Float    @default(0)
  price               Float    @default(0)
  is_vegetarian       Boolean  @default(false)
  product_category_id String
  is_common           Boolean  @default(true)
  user_id             String

  category            ProductCategory    @relation(fields: [product_category_id], references: [id])
  user                User               @relation(fields: [user_id], references: [id])
  ingredients         Ingredient[]
  eating_ingredients  EatingIngredient[] @relation("EatingIngredientProduct")
  prices              Price[]
}

model Price {
  id		      String	     	@id @default(uuid())
  user_id	    String	     
  product_id	String	     
  price		    Float

  user        User            @relation(fields: [user_id], references: [id])
  product     Product         @relation(fields: [product_id], references: [id])
}

model ProductCategory {
  id            String	  @id @default(uuid())
  name          String    @unique   //Мясо, Рыба, Крупы...
  products      Product[]
}

model Hiking {
  id                String	     	@id @default(uuid())
  name              String
  days_total        Int
  members_total     Int
  vegetarians_total Int
  user_id           String	     

  user              User      @relation(fields: [user_id], references: [id])
  eatings           Eating[]
}

model Eating {
  id                String	     	@id @default(uuid())
  hiking_id         String
  day_number        Int
  eating_time_id    String

  hiking            Hiking      @relation(fields: [hiking_id], references: [id])
  eating_time       EatingTime  @relation(fields: [eating_time_id], references: [id])
  eating_ingredients EatingIngredient[]
}

model EatingTime {
  id            String	     	@id @default(uuid())
  name          String    	@unique // "Завтрак", "Обед", "Ужин", "Перекус"
  eatings       Eating[]
}

model EatingIngredient {
  id                String   @id @default(uuid())
  product_id        String
  personal_quantity Float
  total_quantity    Float
  eating_id         String
  product           Product @relation("EatingIngredientProduct", fields: [product_id], references: [id])
  eating            Eating  @relation(fields: [eating_id], references: [id])
}