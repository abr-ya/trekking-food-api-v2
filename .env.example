# Server
PORT=3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Better Auth (generate secret: npm run auth:secret)
BETTER_AUTH_SECRET=your-generated-secret-at-least-32-chars
# API base URL. On Render use https://your-app.onrender.com so session cookies work cross-origin.
BETTER_AUTH_URL=http://localhost:4000

# CORS – comma-separated origins that may call this API (required for cross-origin frontends)
# Example: frontend at http://localhost:5173 calling API at https://api25.site → set this on the API server
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
